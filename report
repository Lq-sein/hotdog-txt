# Load data from file
def load_data(filename):
    vendors = []
    try:
        with open(filename, "r") as file:
            for line in file:
                parts = line.strip().split(",")
                if len(parts) < 7: continue 
                vendor = {
                    "id": parts[0],
                    "name": parts[1],
                    "year_week": parts[2],
                    "vegan": int(parts[3]),
                    "meat": int(parts[4]),
                    "onions": float(parts[5]),
                    "ketchup": float(parts[6])
                }
                vendors.append(vendor)
    except FileNotFoundError:
        print("Error: " + filename + " not found.")
    return vendors

# FIX: Changed search target to check ["id"] instead of ["name"]
def linear_search_unsorted(data, target_id):
    for vendor in data:
        if vendor["id"] == target_id:
            return vendor
    return None

def linear_search_sorted(data, target_id):
    for vendor in data:
        if vendor["id"] == target_id:
            return vendor
        elif vendor["id"] > target_id:
            break 
    return None

# FIX: Changed binary search logic to use ["id"] to match user input
def binary_search(data, target_id):
    low = 0
    high = len(data) - 1
    while low <= high:
        mid = (low + high) // 2
        if data[mid]["id"] == target_id:
            return data[mid]
        elif data[mid]["id"] < target_id:
            low = mid + 1
        else:
            high = mid - 1
    return None

# FIX: Changed bubble sort to sort by ["id"] so Binary Search works
def bubble_sort(data):
    n = len(data)
    for i in range(n):
        for j in range(0, n - i - 1):
            if data[j]["id"] > data[j + 1]["id"]:
                data[j], data[j + 1] = data[j + 1], data[j]
    return data

# FIX: Changed quick sort to sort by ["id"]
def quick_sort(data):
    if len(data) <= 1:
        return data
    pivot = data[0]
    left = [x for x in data[1:] if x["id"] <= pivot["id"]]
    right = [x for x in data[1:] if x["id"] > pivot["id"]]
    return quick_sort(left) + [pivot] + quick_sort(right)
