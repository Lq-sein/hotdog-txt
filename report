# Load data from file
def load_data(filename):
    vendors = []
    try:
        with open(filename, "r") as file:
            for line in file:
                parts = line.strip().split(",")
                if len(parts) < 7: continue 
                vendor = {
                    "id": parts[0],
                    "name": parts[1],
                    "year_week": parts[2],
                    "vegan": int(parts[3]),
                    "meat": int(parts[4]),
                    "onions": float(parts[5]),
                    "ketchup": float(parts[6])
                }
                vendors.append(vendor)
    except FileNotFoundError:
        print("Error: " + filename + " not found.")
    return vendors

# FIX: Changed search target to check ["id"] instead of ["name"]
def linear_search_unsorted(data, target_id):
    for vendor in data:
        if vendor["id"] == target_id:
            return vendor
    return None


def linear_search_sorted(data, target_id):
    for vendor in data:
        if vendor["id"] == target_id:
            return vendor
        elif vendor["id"] > target_id:
            break 
    return None

# FIX: Changed binary search logic to use ["id"] to match user input
def binary_search(data, target_id):
    low = 0
    high = len(data) - 1
    while low <= high:
        mid = (low + high) // 2
        if data[mid]["id"] == target_id:
            return data[mid]
        elif data[mid]["id"] < target_id:
            low = mid + 1
        else:
            high = mid - 1
    return None
